# Copy to `.env.local` and fill in. `.env.local` is gitignored.
# See SETUP.md for the click-by-click setup.

# ---------- App ----------
# Public URL of this app. Used as the OAuth redirect base + Supabase auth redirect.
NEXT_PUBLIC_APP_URL=http://localhost:4380

# Domain that receives inbound forwarded invoices (MX points here).
# Leave as default for local dev; set to your real subdomain in production.
NEXT_PUBLIC_INBOUND_DOMAIN=inbound.payablepilot.com

# ---------- Supabase ----------
# Auth + Postgres + RLS. Create a project at https://supabase.com.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key. Server-only — NEVER ship this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Gmail (Google Cloud Console) ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4380/api/integrations/gmail/callback

# ---------- QuickBooks Online (Intuit Developer) ----------
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=http://localhost:4380/api/integrations/qbo/callback
QBO_ENV=sandbox

# ---------- Anthropic ----------
# Used to extract invoice fields from PDFs.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# ---------- Postmark ----------
# Inbound: a long random string used as the basic-auth password on the
# Postmark inbound webhook. Postmark will send Authorization: Basic <b64>.
POSTMARK_INBOUND_SECRET=
# Outbound: server token from Postmark (used later for digests, reminders).
POSTMARK_SERVER_TOKEN=
