# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored — never commit real credentials.

# ---------- Gmail (Google Cloud Console) ----------
# 1. Create a project at https://console.cloud.google.com
# 2. Enable the Gmail API
# 3. OAuth consent screen — add scope: gmail.readonly
# 4. Create OAuth 2.0 Client ID (Web application)
# 5. Authorized redirect URI: <APP_URL>/api/integrations/gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4380/api/integrations/gmail/callback

# ---------- QuickBooks Online (Intuit Developer) ----------
# 1. Create an app at https://developer.intuit.com/app/developer/dashboard
# 2. Add redirect URI: <APP_URL>/api/integrations/qbo/callback
# 3. QBO_ENV = "sandbox" while testing, "production" once ready.
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=http://localhost:4380/api/integrations/qbo/callback
QBO_ENV=sandbox

# ---------- Claude (Anthropic) ----------
# Used to extract invoice fields (vendor, amount, line items, project ref) from PDFs.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7
